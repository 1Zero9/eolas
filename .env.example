# Eolas Cloud (Next.js app) environment variables
# Copy this file to .env (or .env.local) and fill in real values.

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/eolas"

# Password required to sign in to the web app (single-user auth).
# If unset, defaults to "eolas" — always set this in any real deployment.
AUTH_PASSWORD="9452"

# Shared secret required by the Mac worker to call the /api/workers/* endpoints.
# Generate a long random value and set the same value in the worker's environment.
EOLAS_WORKER_SECRET="bowie2026"

# Google Gemini API key used to power the "Brainstorm with AI" idea feature.
GEMINI_API_KEY="change-me"

# Gemini model to use for brainstorming (e.g. gemini-1.5-flash, gemini-2.0-flash).
GEMINI_MODEL="gemini-1.5-flash"

# --- Mac worker (worker/index.js) environment variables ---

# Base URL of the Eolas Cloud app the worker should poll.
EOLAS_CLOUD_URL="http://localhost:3000"

# Unique name identifying this worker instance.
EOLAS_WORKER_NAME="eolas-worker-local"

# Absolute path to the root directory the worker is allowed to write projects into.
EOLAS_PROJECT_ROOT="/Users/you/Projects"

# Must match the cloud app's EOLAS_WORKER_SECRET value above.
EOLAS_WORKER_SECRET="change-me"
